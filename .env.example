# SailBook environment variables
#
# Copy to `.env.local` for local dev. For Vercel, set these in
# Project Settings → Environment Variables, scoped to the right env
# (Production, Preview, or both). See docs/STAGING.md for full setup.
#
# Legend: [prod] = different value per environment, [shared] = same everywhere

# ─── Supabase ─────────────────────────────────────────────────────────
# Local dev: get values from `supabase status` after `supabase start`.
# Preview (Vercel): point at the staging Supabase project.
# Production (Vercel): point at the production Supabase project.
NEXT_PUBLIC_SUPABASE_URL=                  # [prod] e.g. https://abc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=             # [prod] anon/publishable key
SUPABASE_SERVICE_ROLE_KEY=                 # [prod] service role key — server only, never expose

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000 # [prod] e.g. https://sailbook.app
NEXT_PUBLIC_DEV_MODE=true                  # [prod] 'true' shows dev helpers; leave unset/false in prod
ENROLLMENT_HOLD_MINUTES=15                 # [shared] minutes to hold a seat during checkout

# ─── Stripe ───────────────────────────────────────────────────────────
# Preview: use test-mode keys (sk_test_…, whsec_… from a test endpoint).
# Production: use live-mode keys.
STRIPE_SECRET_KEY=                         # [prod] sk_test_… (preview) or sk_live_… (prod)
STRIPE_WEBHOOK_SECRET=                     # [prod] whsec_… from the matching endpoint

# ─── Notifications ────────────────────────────────────────────────────
# Set NOTIFICATIONS_ENABLED=false in dev/CI to skip real sends.
NOTIFICATIONS_ENABLED=false                # [prod] 'true' in prod, 'false' in preview/dev/CI
# SMS kill-switch. V2 ships email-only (A2P 10DLC unapproved). Set 'true' in
# dev/CI/test to keep the SMS path covered; leave unset/false in prod.
SMS_ENABLED=true                           # [dev/CI] 'true' to exercise SMS path; prod stays unset
TWILIO_ACCOUNT_SID=                        # [prod] from twilio.com console
TWILIO_AUTH_TOKEN=                         # [prod]
TWILIO_FROM_NUMBER=                        # [prod] e.g. +15551234567 (verified toll-free)
RESEND_API_KEY=                            # [prod] re_… from resend.com

# ─── Cron protection ──────────────────────────────────────────────────
# Vercel cron requests carry this in the Authorization header. Generate
# a long random string per environment.
CRON_SECRET=                               # [prod] random 32+ char string
